<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="page-hero">
  <div class="wrap">
    <p class="hero-kicker reveal"><a class="crumb" href="/aktuelt">← Aktuelt</a></p>
    <h1 class="page-title reveal"><%= post.title %></h1>
    <p class="hero-kicker reveal" style="margin-top:.8rem"><%= fmtPostDate(post.created_at) %></p>
  </div>
  <div class="page-hero-road" aria-hidden="true"></div>
</section>

<section class="section">
  <div class="wrap narrow">
    <% if (post.image) { %>
      <figure class="photo-card reveal" style="margin:0 0 2rem">
        <img src="<%= post.image %>" alt="" width="1200" height="675">
      </figure>
    <% } %>
    <div class="prose reveal">
      <% String(post.body).split('\n').filter(Boolean).forEach(function(p) { %><p class="lead"><%= p %></p><% }) %>
    </div>
    <p class="reveal" style="margin-top:2.5rem">
      <a class="btn btn-ghost" href="/aktuelt">← Fleire nyheiter</a>
      <a class="btn btn-primary" href="/kurs">Sjå kurskalenderen</a>
    </p>
  </div>
</section>

<%- include('partials/footer') %>
