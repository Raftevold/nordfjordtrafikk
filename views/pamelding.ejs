<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="page-hero">
  <div class="wrap">
    <p class="hero-kicker reveal">Vi tek kontakt med deg</p>
    <h1 class="page-title reveal">Påmelding til opplæring</h1>
  </div>
  <div class="page-hero-road" aria-hidden="true"></div>
</section>

<section class="section">
  <div class="wrap form-layout">
    <div class="form-aside reveal">
      <p class="lead"><%= pages.pamelding.intro %></p>
      <h2 class="aside-title">Har du spørsmål?</h2>
      <ul class="aside-phones">
        <% locations.forEach(function(l) { %>
          <li><a href="tel:+47<%= String(l.phone).replace(/\s/g,'') %>"><strong><%= l.name %></strong> <%= l.phone %></a></li>
        <% }) %>
      </ul>
      <img class="form-illu" src="/img/skulebil-sedan.webp" alt="" width="420" height="219" loading="lazy" aria-hidden="true">
    </div>

    <div class="signup-box reveal" style="--d:.15s">
      <h2>Fyll ut og send inn</h2>
      <form class="js-form" data-endpoint="/api/request" novalidate>
        <p class="visually-hidden" aria-hidden="true"><label>Ikkje fyll ut dette feltet: <input type="text" name="website" tabindex="-1" autocomplete="off"></label></p>
        <div class="field">
          <label for="r-name">Fullt namn <span class="req" aria-hidden="true">*</span></label>
          <input id="r-name" name="name" type="text" required autocomplete="name">
        </div>
        <div class="field">
          <label for="r-birth">Fødselsdato <span class="req" aria-hidden="true">*</span></label>
          <input id="r-birth" name="birthdate" type="date" required autocomplete="bday">
        </div>
        <div class="field-row">
          <div class="field">
            <label for="r-phone">Telefonnummer <span class="req" aria-hidden="true">*</span></label>
            <input id="r-phone" name="phone" type="tel" required autocomplete="tel">
          </div>
          <div class="field">
            <label for="r-email">E-postadresse <span class="req" aria-hidden="true">*</span></label>
            <input id="r-email" name="email" type="email" required autocomplete="email">
          </div>
        </div>
        <div class="field">
          <label for="r-klass">Velg klasse <span class="req" aria-hidden="true">*</span></label>
          <select id="r-klass" name="klass" required>
            <option value="" disabled selected>– Vel førarkortklasse –</option>
            <% classes.forEach(function(k) { %>
              <option value="<%= k.label %>"><%= k.label %></option>
            <% }) %>
          </select>
        </div>
        <div class="field">
          <label for="r-loc">Velg avdeling <span class="req" aria-hidden="true">*</span></label>
          <select id="r-loc" name="location" required>
            <option value="" disabled selected>– Vel avdeling –</option>
            <option>Nordfjordeid</option>
            <option>Stranda</option>
            <option>Stryn</option>
            <option>Sykkylven</option>
          </select>
        </div>
        <div class="field">
          <label for="r-note">Melding (valfritt)</label>
          <textarea id="r-note" name="note" rows="3" placeholder="T.d. når du ønskjer å starte"></textarea>
        </div>
        <button class="btn btn-primary btn-lg" type="submit">Bestill opplæring</button>
        <p class="form-status" role="status" aria-live="polite"></p>
        <p class="muted small">Vi brukar opplysningane berre til å følgje opp førespurnaden din. Les <a href="/personvern">personvernerklæringa</a>.</p>
      </form>
      <template data-success>
        <div class="form-success">
          <h3>Takk for påmeldinga! ✅</h3>
          <p>Vi tek kontakt med deg så snart vi kan og avtalar opplæring som er tilpassa deg.</p>
        </div>
      </template>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
