<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="hero" aria-label="Velkomen">
  <div class="hero-sky" aria-hidden="true">
    <svg class="hero-mountains" viewBox="0 0 1440 220" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0 220 L0 150 Q120 60 260 130 T520 110 Q640 30 780 120 T1050 100 Q1180 40 1300 110 L1440 90 L1440 220 Z" fill="#1a2029"/>
      <path d="M0 220 L0 180 Q180 110 340 165 T660 150 Q820 80 980 155 T1290 140 L1440 130 L1440 220 Z" fill="#141922"/>
    </svg>
  </div>
  <div class="wrap hero-inner">
    <div class="hero-copy">
      <p class="hero-kicker reveal"><%= pages.home.heroKicker %></p>
      <h1 class="hero-title">
        <span class="hero-line"><span>Det første steget</span></span>
        <span class="hero-line"><span>til <em class="hero-em">lappen</em></span></span>
      </h1>
      <p class="hero-sub reveal" style="--d:.35s"><%= pages.home.heroSub %></p>
      <div class="hero-actions reveal" style="--d:.5s">
        <a class="btn btn-primary btn-lg" href="/kurs">Meld deg på kurs</a>
        <a class="btn btn-outline-light btn-lg" href="/pamelding">Bestill opplæring</a>
      </div>
      <ul class="hero-phones reveal" style="--d:.65s" aria-label="Ring avdelinga di">
        <% settings.locations.forEach(function(l) { %>
          <li><a href="tel:+47<%= String(l.phone).replace(/\s/g,'') %>"><span class="phone-dot" aria-hidden="true"></span><%= l.name %> · <%= l.phone %></a></li>
        <% }) %>
      </ul>
    </div>
  </div>
  <div class="hero-road" aria-hidden="true">
    <div class="road-lines"></div>
    <img class="hero-car" src="/img/skulebil-sedan.webp" alt="" width="560" height="292" fetchpriority="high">
  </div>
</section>

<section class="stats" aria-label="Nøkkeltal">
  <div class="wrap stats-grid">
    <div class="stat reveal"><span class="stat-num" data-count="<%= pages.home.statYear %>"><%= pages.home.statYear %></span><span class="stat-label"><%= pages.home.statYearLabel %></span></div>
    <div class="stat reveal" style="--d:.1s"><span class="stat-num" data-count="<%= pages.home.statClasses %>"><%= pages.home.statClasses %></span><span class="stat-label"><%= pages.home.statClassesLabel %></span></div>
    <div class="stat reveal" style="--d:.2s"><span class="stat-num" data-count="<%= pages.home.statTeam %>"><%= pages.home.statTeam %></span><span class="stat-label"><%= pages.home.statTeamLabel %></span></div>
    <div class="stat reveal" style="--d:.3s"><span class="stat-num" data-count="<%= pages.home.statLocations %>"><%= pages.home.statLocations %></span><span class="stat-label"><%= pages.home.statLocationsLabel %></span></div>
  </div>
</section>

<section class="section" aria-labelledby="usp-tittel">
  <div class="wrap">
    <h2 class="section-title reveal" id="usp-tittel"><%= pages.home.uspTitle %></h2>
    <div class="usp-grid">
      <% pages.home.usps.forEach(function(u, i) { %>
        <article class="usp-card reveal" style="--d:<%= i * 0.1 %>s">
          <span class="usp-icon" aria-hidden="true">
            <% if (u.icon === 'road') { %><svg viewBox="0 0 24 24"><path fill="currentColor" d="M4 22 9 2h2l-.6 2.4L10 6h4l-.4-1.6L13 2h2l5 20h-4l-.9-3.6H8.9L8 22Zm5.9-7.6h4.2L13 9.6h-2Z"/></svg>
            <% } else if (u.icon === 'price') { %><svg viewBox="0 0 24 24"><path fill="currentColor" d="m21.4 11.6-9-9A2 2 0 0 0 11 2H4a2 2 0 0 0-2 2v7c0 .5.2 1 .6 1.4l9 9a2 2 0 0 0 2.8 0l7-7a2 2 0 0 0 0-2.8ZM6.5 8A1.5 1.5 0 1 1 8 6.5 1.5 1.5 0 0 1 6.5 8Z"/></svg>
            <% } else if (u.icon === 'car') { %><svg viewBox="0 0 24 24"><path fill="currentColor" d="M18.9 6a1.5 1.5 0 0 0-1.4-1H6.5A1.5 1.5 0 0 0 5.1 6L3 12v8a1 1 0 0 0 1 1h1a1 1 0 0 0 1-1v-1h12v1a1 1 0 0 0 1 1h1a1 1 0 0 0 1-1v-8ZM6.9 7h10.2l1.4 4H5.5ZM7 15.5A1.5 1.5 0 1 1 8.5 14 1.5 1.5 0 0 1 7 15.5Zm10 0a1.5 1.5 0 1 1 1.5-1.5 1.5 1.5 0 0 1-1.5 1.5Z"/></svg>
            <% } else { %><svg viewBox="0 0 24 24"><path fill="currentColor" d="M12 2a7 7 0 0 0-7 7c0 5.2 7 13 7 13s7-7.8 7-13a7 7 0 0 0-7-7Zm0 9.5A2.5 2.5 0 1 1 14.5 9 2.5 2.5 0 0 1 12 11.5Z"/></svg><% } %>
          </span>
          <h3><%= u.title %></h3>
          <p><%= u.text %></p>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<% if (courses.length) { %>
<section class="section section-dark" aria-labelledby="kurs-tittel">
  <div class="wrap">
    <div class="section-head reveal">
      <h2 class="section-title" id="kurs-tittel">Kommande kurs</h2>
      <a class="btn btn-outline-light" href="/kurs">Sjå alle kurs</a>
    </div>
    <div class="course-grid">
      <% courses.forEach(function(c, i) { %>
        <article class="course-card reveal" style="--d:<%= i * 0.12 %>s">
          <div class="course-meta">
            <span class="badge badge-loc"><%= c.location %></span>
            <% if (c.type) { %><span class="badge badge-type"><%= c.type %></span><% } %>
          </div>
          <h3><%= c.title %></h3>
          <p class="course-date">
            <svg viewBox="0 0 24 24" aria-hidden="true" class="icon-inline"><path fill="currentColor" d="M19 4h-1V2h-2v2H8V2H6v2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Zm0 16H5V10h14ZM5 8V6h14v2Z"/></svg>
            <%= fmtDateRange(c.starts_at, c.ends_at) %>
          </p>
          <% if (c.capacity > 0) { %>
            <div class="capacity" role="img" aria-label="<%= Math.max(0, c.capacity - c.taken) %> av <%= c.capacity %> plassar ledige">
              <div class="capacity-bar"><span style="--fill:<%= Math.min(100, Math.round(c.taken / c.capacity * 100)) %>%"></span></div>
              <small><%= Math.max(0, c.capacity - c.taken) %> plassar att</small>
            </div>
          <% } %>
          <a class="btn btn-primary" href="/kurs/<%= c.id %>">Meld deg på</a>
        </article>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<section class="section" aria-labelledby="team-tittel">
  <div class="wrap">
    <div class="section-head reveal">
      <h2 class="section-title" id="team-tittel">Møt laget vårt</h2>
      <a class="btn btn-ghost" href="/om-oss">Om trafikkskulen →</a>
    </div>
    <div class="team-strip">
      <% team.slice(0, 4).forEach(function(t, i) { %>
        <article class="team-mini reveal" style="--d:<%= i * 0.1 %>s">
          <img src="<%= t.img %>" alt="Portrett av <%= t.name %>" width="120" height="120" loading="lazy">
          <h3><%= t.name %></h3>
          <p><%= t.role %></p>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<% if (posts && posts.length) { %>
<section class="section section-tight" aria-labelledby="aktuelt-tittel">
  <div class="wrap">
    <div class="section-head reveal">
      <h2 class="section-title" id="aktuelt-tittel">Aktuelt</h2>
      <a class="btn btn-ghost" href="/aktuelt">Alle nyheiter →</a>
    </div>
    <div class="news-grid news-grid-2">
      <% posts.forEach(function(p, i) { %>
        <article class="news-card reveal" style="--d:<%= i * 0.1 %>s">
          <% if (p.image) { %><a href="/aktuelt/<%= p.id %>" tabindex="-1" aria-hidden="true"><img src="<%= p.image %>" alt="" width="480" height="270" loading="lazy"></a><% } %>
          <div class="news-body">
            <p class="news-date"><%= fmtPostDate(p.created_at) %></p>
            <h3><a href="/aktuelt/<%= p.id %>"><%= p.title %></a></h3>
            <p class="news-excerpt"><%= String(p.body).replace(/\s+/g, ' ').slice(0, 120) %><%= p.body.length > 120 ? ' …' : '' %></p>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<section class="section section-tight" aria-label="Gåvekort">
  <div class="wrap">
    <a class="gift-banner reveal" href="/gavekort">
      <div>
        <h2>Gje vekk lappen i gåve 🎁</h2>
        <p>Gåvekort på trafikkopplæring – gyldig for alle lette klassar, trafikalt grunnkurs og mørkekøyring.</p>
      </div>
      <span class="btn btn-light">Bestill gåvekort</span>
    </a>
  </div>
</section>

<%- include('partials/footer') %>
