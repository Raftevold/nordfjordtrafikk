<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="page-hero">
  <div class="wrap">
    <p class="hero-kicker reveal"><a class="crumb" href="/om-oss">← Om oss</a></p>
    <h1 class="page-title reveal">Skulebilane våre</h1>
  </div>
  <div class="page-hero-road" aria-hidden="true"></div>
</section>

<section class="section">
  <div class="wrap">
    <p class="lead narrow-p reveal"><%= pages.om.cars %></p>
    <div class="vehicle-grid">
      <% vehicles.forEach(function(v, i) { %>
        <article class="vehicle-card reveal" style="--d:<%= (i % 3) * 0.1 %>s">
          <% if (v.img) { %>
            <img src="<%= v.img %>" alt="<%= v.name %>" width="480" height="300" loading="lazy">
          <% } else { %>
            <div class="vehicle-placeholder" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path fill="currentColor" d="M18.9 6a1.5 1.5 0 0 0-1.4-1H6.5A1.5 1.5 0 0 0 5.1 6L3 12v8a1 1 0 0 0 1 1h1a1 1 0 0 0 1-1v-1h12v1a1 1 0 0 0 1 1h1a1 1 0 0 0 1-1v-8ZM6.9 7h10.2l1.4 4H5.5ZM7 15.5A1.5 1.5 0 1 1 8.5 14 1.5 1.5 0 0 1 7 15.5Zm10 0a1.5 1.5 0 1 1 1.5-1.5 1.5 1.5 0 0 1-1.5 1.5Z"/></svg>
              <span>Bilete kjem</span>
            </div>
          <% } %>
          <div class="vehicle-body">
            <h2><%= v.name %></h2>
            <% if (v.desc) { %><p><%= v.desc %></p><% } %>
          </div>
        </article>
      <% }) %>
    </div>
    <p class="center reveal" style="margin-top:2.5rem">
      <a class="btn btn-primary btn-lg" href="/pamelding">Meld deg på opplæring</a>
    </p>
  </div>
</section>

<%- include('partials/footer') %>
